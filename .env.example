# Public client-side env vars (Vite exposes anything prefixed with VITE_).
# Copy to `.env` for local dev. Production values are set in the
# Cloudflare Pages dashboard under the project's build environment variables.

# Google reCAPTCHA v2 site key (public — safe to expose in the browser).
# Pair with RECAPTCHA_SECRET_KEY in `.dev.vars` / Cloudflare secrets.
VITE_RECAPTCHA_SITE_KEY=
